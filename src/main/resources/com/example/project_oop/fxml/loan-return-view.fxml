<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1030.0" spacing="25.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.LoanReturnController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="Loan &amp; Return Management" textFill="#1e2b3c">
        <font><Font name="System Bold" size="28.0" /></font>
    </Label>

    <HBox spacing="30.0">
        <VBox spacing="15.0" styleClass="action-form-card" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
            <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
            <children>
                <Label text="Issue Book (Lend)" textFill="#4a90e2">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <VBox spacing="10.0">
                    <Label text="Reader ID:" textFill="#64748b"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <TextField promptText="Scan or enter Reader ID..." styleClass="modern-input" />
                </VBox>
                <VBox spacing="10.0">
                    <Label text="Book ID / ISBN:" textFill="#64748b"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <TextField promptText="Scan or enter Book ID..." styleClass="modern-input" />
                </VBox>
                <Region VBox.vgrow="ALWAYS" /> <Button maxWidth="1.7976931348623157E308" prefHeight="40.0" styleClass="btn-primary" text="Issue Book" textFill="WHITE">
                <font><Font name="System Bold" size="14.0" /></font>
            </Button>
            </children>
        </VBox>

        <VBox spacing="15.0" styleClass="action-form-card" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
            <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
            <children>
                <Label text="Process Return" textFill="#10b981">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <VBox spacing="10.0">
                    <Label text="Loan ID / Book ID:" textFill="#64748b"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <TextField promptText="Scan or enter ID to return..." styleClass="modern-input" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="65.0" style="-fx-background-color: #f8fafc; -fx-background-radius: 5; -fx-border-color: #e2e8f0; -fx-border-radius: 5;">
                    <Label text="Scan a book to see return details" textFill="#94a3b8">
                        <font><Font name="System Italic" size="12.0" /></font>
                    </Label>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="1.7976931348623157E308" prefHeight="40.0" styleClass="btn-success" text="Confirm Return" textFill="WHITE">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </VBox>
    </HBox>

    <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
        <padding><Insets bottom="10.0" left="15.0" right="15.0" top="15.0" /></padding>
        <children>
            <HBox alignment="CENTER_LEFT">
                <Label text="Current Active Loans" textFill="#334155">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" prefWidth="250.0" styleClass="search-box">
                    <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.5" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../img/avatar.jpg" /></image>
                    </ImageView>
                    <TextField promptText="Search active loans..." style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />
                </HBox>
            </HBox>

            <TableView fx:id="activeLoansTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn prefWidth="90.0" text="Loan ID" />
                    <TableColumn prefWidth="150.0" text="Reader Name" />
                    <TableColumn prefWidth="250.0" text="Book Title" />
                    <TableColumn prefWidth="110.0" text="Issue Date" />
                    <TableColumn prefWidth="110.0" text="Due Date" />
                    <TableColumn prefWidth="100.0" text="Status" />
                    <TableColumn prefWidth="120.0" text="Action" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </VBox>
</VBox>