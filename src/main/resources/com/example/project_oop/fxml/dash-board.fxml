<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1030.0" spacing="25.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.DashBoardController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>

        <VBox spacing="5.0">
            <Label fx:id="welcomeLabel" text="Welcome back, Admin!" textFill="#64748b">
                <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label text="Library Overview" textFill="#1e2b3c">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </VBox>

        <HBox spacing="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="15.0" styleClass="stat-card, card-blue" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label text="TOTAL BOOKS" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                            <Label text="24,500" textFill="#1e2b3c"><font><Font name="System Bold" size="26.0" /></font></Label>
                        </VBox>
                        <ImageView fitHeight="45.0" fitWidth="45.0" opacity="0.8" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../img/avatar.jpg" /></image>
                        </ImageView>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="15.0" styleClass="stat-card, card-green" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label text="TOTAL READERS" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                            <Label text="12,350" textFill="#1e2b3c"><font><Font name="System Bold" size="26.0" /></font></Label>
                        </VBox>
                        <ImageView fitHeight="45.0" fitWidth="45.0" opacity="0.8" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../img/avatar.jpg" /></image>
                        </ImageView>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="15.0" styleClass="stat-card, card-orange" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label text="BOOKS ON LOAN" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                            <Label text="8,210" textFill="#1e2b3c"><font><Font name="System Bold" size="26.0" /></font></Label>
                        </VBox>
                        <ImageView fitHeight="45.0" fitWidth="45.0" opacity="0.8" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../img/avatar.jpg" /></image>
                        </ImageView>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="15.0" styleClass="stat-card, card-red" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label text="OVERDUE ITEMS" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                            <Label text="345" textFill="#ef4444"><font><Font name="System Bold" size="26.0" /></font></Label>
                        </VBox>
                        <ImageView fitHeight="45.0" fitWidth="45.0" opacity="0.8" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@../img/avatar.jpg" /></image>
                        </ImageView>
                    </children>
                </HBox>
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recent Transactions" textFill="#334155">
                                <font><Font name="System Bold" size="18.0" /></font>
                            </Label>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="View All" textFill="#4a90e2" underline="true" style="-fx-cursor: hand;">
                                <font><Font name="System Bold" size="13.0" /></font>
                            </Label>
                        </HBox>
                        <Region prefHeight="15.0" />

                        <TableView fx:id="recentActivityTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="80.0" text="Loan ID" />
                                <TableColumn prefWidth="150.0" text="Reader" />
                                <TableColumn prefWidth="200.0" text="Book Title" />
                                <TableColumn prefWidth="100.0" text="Date" />
                                <TableColumn prefWidth="90.0" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox prefWidth="350.0" spacing="20.0" HBox.hgrow="NEVER">
                    <children>
                        <VBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
                            <children>
                                <Label text="Book Status Overview" textFill="#334155" alignment="CENTER">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <PieChart fx:id="bookStatusChart" legendSide="BOTTOM" labelsVisible="false" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox style="-fx-background-color: #fff1f2; -fx-border-color: #fecdd3; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <children>
                                <Label text="⚠️ Action Required" textFill="#e11d48">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Region prefHeight="5.0" />
                                <Label text="• 15 books are overdue this week." textFill="#881337" wrapText="true" />
                                <Label text="• 3 reader memberships expiring today." textFill="#881337" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>

    </children>
</VBox>