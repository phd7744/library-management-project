<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.PortalController">
    <left>
        <VBox prefWidth="260.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="8.0">
                    <padding>
                        <Insets top="32.0" right="20.0" bottom="24.0" left="20.0" />
                    </padding>
                    <children>
                        <Label text="Library Management" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label text="Employee Portal" textFill="LIGHTBLUE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="12.0">
                    <padding>
                        <Insets left="10.0" right="10.0" />
                    </padding>
                    <children>
                        <Button maxWidth="1.7976931348623157E308" prefHeight="44.0" styleClass="sidebar-btn" text="Dashboard" textFill="WHITE" />
                        <Button maxWidth="1.7976931348623157E308" prefHeight="44.0" styleClass="sidebar-btn" text="Book Inventory" textFill="WHITE" />
                        <Button maxWidth="1.7976931348623157E308" prefHeight="44.0" styleClass="sidebar-btn" text="Loan / Return" textFill="WHITE" />
                        <Button maxWidth="1.7976931348623157E308" prefHeight="44.0" styleClass="sidebar-btn" text="Reader Records" textFill="WHITE" />
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" styleClass="sidebar-btn" text="Log Out" textFill="#ff6b6b">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                    <VBox.margin>
                        <Insets bottom="30.0" left="10.0" right="10.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="16.0" styleClass="dashboard-root" BorderPane.alignment="CENTER">
            <children>
                <Label text="Welcome, Employee">
                    <font>
                        <Font name="System Bold" size="36.0" />
                    </font>
                </Label>
                <Label text="Ban co the quan ly muon tra, cap nhat sach va xu ly thong tin doc gia." textFill="#475569">
                    <font>
                        <Font size="17.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>
</BorderPane>
