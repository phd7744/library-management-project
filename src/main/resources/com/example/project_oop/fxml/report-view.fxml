<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1030.0" spacing="20.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.ReportController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <children>
            <Label text="Reports &amp; Analytics" textFill="#1e2b3c">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button alignment="CENTER" prefHeight="40.0" style="-fx-background-color: #10b981; -fx-background-radius: 8; -fx-cursor: hand;" text="Export to Excel" textFill="WHITE">
                <font><Font name="System Bold" size="14.0" /></font>
                <effect><DropShadow color="#10b98166" offsetY="4.0" radius="5.0" /></effect>
                <padding><Insets left="20.0" right="20.0" /></padding>
            </Button>
        </children>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;">
        <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="3.0" radius="5.0" /></effect>
        <children>
            <VBox spacing="5.0">
                <Label text="Report Type" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                <ComboBox prefWidth="180.0" promptText="Borrowing History" styleClass="modern-combo" />
            </VBox>

            <VBox spacing="5.0">
                <Label text="From Date" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                <DatePicker promptText="Select Start Date" styleClass="modern-datepicker" />
            </VBox>

            <VBox spacing="5.0">
                <Label text="To Date" textFill="#64748b"><font><Font name="System Bold" size="12.0" /></font></Label>
                <DatePicker promptText="Select End Date" styleClass="modern-datepicker" />
            </VBox>

            <VBox alignment="BOTTOM_LEFT" spacing="5.0">
                <Button prefHeight="30.0" styleClass="btn-primary" text="Generate Report" textFill="WHITE">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </VBox>
        </children>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <children>

            <VBox prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 10;" HBox.hgrow="NEVER">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
                <children>
                    <Label text="Monthly Loan Trends" textFill="#334155">
                        <font><Font name="System Bold" size="16.0" /></font>
                        <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                    </Label>

                    <BarChart fx:id="reportChart" animated="true" legendVisible="false" VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis side="BOTTOM" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis side="LEFT" />
                        </yAxis>
                    </BarChart>
                </children>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <effect><DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" /></effect>
                <children>
                    <Label text="Detailed Records" textFill="#334155">
                        <font><Font name="System Bold" size="16.0" /></font>
                        <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                    </Label>
                    <TableView fx:id="reportTableView" styleClass="modern-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="80.0" text="Record ID" />
                            <TableColumn prefWidth="120.0" text="Date" />
                            <TableColumn prefWidth="200.0" text="Description / Book" />
                            <TableColumn prefWidth="120.0" text="User / Reader" />
                            <TableColumn prefWidth="100.0" text="Status" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>

        </children>
    </HBox>
</VBox>