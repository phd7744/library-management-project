<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.project_oop.controller.publisher.PublisherController"
      VBox.vgrow="ALWAYS" spacing="15" style="-fx-padding: 20;">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="tfSearch" promptText="Tìm kiếm theo tên NXB..." HBox.hgrow="ALWAYS"
                   style="-fx-font-size: 13; -fx-padding: 8;"/>
        <Button fx:id="btnAddPublisher"
        text="+ Add Publisher"
        style="-fx-font-size: 13; 
               -fx-padding: 8 20; 
               -fx-background-color: #2196F3; 
               -fx-text-fill: white; 
               -fx-background-radius: 5;"/>
    </HBox>

    <TableView fx:id="tblPublisher" editable="false" VBox.vgrow="ALWAYS"
               style="-fx-font-size: 12;">

        <columns>

            <TableColumn text="ID" prefWidth="60" sortable="false"
                         style="-fx-alignment: CENTER;">
                <cellValueFactory>
                    <PropertyValueFactory property="publisherId"/>
                </cellValueFactory>
            </TableColumn>

            <TableColumn text="Tên NXB" prefWidth="200" sortable="false">
                <cellValueFactory>
                    <PropertyValueFactory property="publisherName"/>
                </cellValueFactory>
            </TableColumn>

            <TableColumn text="Địa chỉ" prefWidth="250" sortable="false">
                <cellValueFactory>
                    <PropertyValueFactory property="publisherAddress"/>
                </cellValueFactory>
            </TableColumn>

            <TableColumn fx:id="colActions" text="Hành động" prefWidth="150" sortable="false" style="-fx-alignment: CENTER;"/>

        </columns>

    </TableView>

</VBox>
