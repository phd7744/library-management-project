<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1030.0" spacing="25.0"
      styleClass="dashboard-root" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.project_oop.controller.CategoryController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <HBox alignment="CENTER_LEFT" spacing="15.0">
      <children>
         <Label text="Categories" textFill="#1e2b3c">
            <font><Font name="System Bold" size="28.0" /></font>
         </Label>

         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnAddCategory"
                 alignment="CENTER"
                 onAction="#handleAddCategory"
                 prefHeight="40.0"
                 styleClass="btn-primary"
                 text="+ Add New Category"
                 textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
            <effect><DropShadow color="#4a90e266" offsetY="4.0" radius="5.0" /></effect>
            <padding><Insets left="20.0" right="20.0" /></padding>
         </Button>
      </children>
   </HBox>

   <VBox style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
      <effect>
         <DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" />
      </effect>
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>
      <children>
         <TableView fx:id="categoryTableView" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colCatId" prefWidth="80.0" text="ID" />
               <TableColumn fx:id="colCatName" prefWidth="600.0" text="Category Name" />
               <TableColumn fx:id="colCatAction" prefWidth="150.0" text="Actions" />
            </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         </TableView>
      </children>
   </VBox>
</VBox>
