<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="900.0" spacing="20.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.reader.AddReaderController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <VBox spacing="5.0">
            <Label text="Register New Reader" textFill="#1e2b3c">
                <font><Font name="System Bold" size="26.0" /></font>
            </Label>
        </VBox>

        <VBox spacing="30.0" style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <effect>
                <DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" />
            </effect>
            <children>
                <HBox spacing="50.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Personal Information" textFill="#1e2b3c">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                    <VBox.margin><Insets bottom="5.0" /></VBox.margin>
                                </Label>

                                <VBox spacing="8.0">
                                    <Label styleClass="input-label" text="Full Name (*)" />
                                    <TextField fx:id="txtFullName" prefHeight="40.0" promptText="Enter full name..." styleClass="modern-input" />
                                </VBox>

                                <VBox spacing="8.0">
                                    <Label styleClass="input-label" text="Phone Number" />
                                    <TextField fx:id="txtPhone" prefHeight="40.0" promptText="Enter phone number..." styleClass="modern-input" />
                                </VBox>
                                <Region VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Account Setup" textFill="#1e2b3c">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                    <VBox.margin><Insets bottom="5.0" /></VBox.margin>
                                </Label>

                                <VBox spacing="8.0">
                                    <Label styleClass="input-label" text="Username (*)" />
                                    <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Create a username for login..." styleClass="modern-input" />
                                </VBox>

                                <VBox spacing="8.0">
                                    <Label styleClass="input-label" text="Password (*)" />
                                    <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Create password..." styleClass="modern-input" />
                                </VBox>

                                <VBox spacing="8.0">
                                    <Label styleClass="input-label" text="Confirm Password (*)" />
                                    <PasswordField fx:id="txtConfirmPassword" prefHeight="40.0" promptText="Re-enter password..." styleClass="modern-input" />
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Region prefHeight="10.0" />

                <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancel" textFill="#64748b">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnAddReader" mnemonicParsing="false" onAction="#handleAddReader" prefHeight="40.0" prefWidth="150.0" styleClass="btn-primary" text="Register Reader" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <effect><DropShadow color="#4a90e266" offsetY="4.0" radius="5.0" /></effect>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</VBox>
