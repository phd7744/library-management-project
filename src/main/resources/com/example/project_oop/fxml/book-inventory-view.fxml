<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1030.0" spacing="25.0" styleClass="dashboard-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project_oop.controller.BookInventoryController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <HBox alignment="CENTER_LEFT" spacing="15.0">
      <children>
         <Label text="Book Inventory" textFill="#1e2b3c">
            <font><Font name="System Bold" size="28.0" /></font>
         </Label>

         <Region HBox.hgrow="ALWAYS" />

         <HBox alignment="CENTER_LEFT" prefWidth="300.0" styleClass="search-box">
            <children>
               <ImageView fitHeight="18.0" fitWidth="18.0" opacity="0.5" pickOnBounds="true" preserveRatio="true">
                  <image><Image url="@../img/avatar.jpg" /></image>
               </ImageView>
               <TextField promptText="Search by title, author, or ISBN..." style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                  <font><Font size="13.0" /></font>
               </TextField>
            </children>
         </HBox>

         <Button alignment="CENTER" prefHeight="40.0" styleClass="btn-primary" text="+ Add New Book" textFill="WHITE">
            <font><Font name="System Bold" size="14.0" /></font>
            <effect><DropShadow color="#4a90e266" offsetY="4.0" radius="5.0" /></effect>
            <padding><Insets left="20.0" right="20.0" /></padding>
         </Button>
      </children>
   </HBox>

   <HBox alignment="CENTER_LEFT" spacing="15.0">
      <children>
         <ComboBox prefWidth="160.0" promptText="All Categories" styleClass="combo-filter" />
         <ComboBox prefWidth="160.0" promptText="Stock Status" styleClass="combo-filter" />
         <Button style="-fx-background-color: transparent; -fx-cursor: hand;" text="Clear Filters" textFill="#8492a6" underline="true">
            <font><Font name="System Italic" size="13.0" /></font>
         </Button>
      </children>
   </HBox>

   <VBox style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
      <effect>
         <DropShadow color="#e2e8f0" offsetX="0.0" offsetY="5.0" radius="10.0" />
      </effect>
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>
      <children>
         <TableView fx:id="bookTableView" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
               <TableColumn fx:id="colTitle" prefWidth="250.0" text="Book Title" />
               <TableColumn fx:id="colCategory" prefWidth="130.0" text="Category" />
               <TableColumn fx:id="colAuthor" prefWidth="150.0" text="Author" />
               <TableColumn fx:id="colPublisher" prefWidth="150.0" text="Publisher" />
               <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Quantity" />
               <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
               <TableColumn fx:id="colAction" prefWidth="100.0" text="Actions" />
            </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         </TableView>
      </children>
   </VBox>
</VBox>